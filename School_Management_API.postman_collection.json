    "item": [
        {
            "name": "Add School",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Delhi Public School\",\n  \"address\": \"Sector 12, Dwarka\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090\n}"
                },
                "url": {
                    "raw": "{{base_url}}/schools/add",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "schools",
                        "add"
                    ]
                },
                "description": "POST /api/schools/add"
            },
            "response": [
                {
                    "name": "201 Created",
                    "status": "Created",
                    "code": 201,
                    "_postman_previewlanguage": "json",
                    "header": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        }
                    ],
                    "body": "{\n  \"success\": true,\n  \"message\": \"School added successfully\"\n}"
                },
                {
                    "name": "400 Bad Request",
                    "status": "Bad Request",
                    "code": 400,
                    "_postman_previewlanguage": "json",
                    "header": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        }
                    ],
                    "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\"\n}"
                }
            ]
        },
        {
